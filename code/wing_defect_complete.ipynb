import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import os
import cv2
import random
from sklearn.model_selection import train_test_split
from sklearn.metrics import confusion_matrix, classification_report, accuracy_score, precision_score, recall_score, f1_score
import tensorflow as tf
from tensorflow import keras
from tensorflow.keras import layers, Sequential
from tensorflow.keras.layers import Conv2D, MaxPooling2D, Flatten, Dense, Dropout, BatchNormalization, Input
from tensorflow.keras.preprocessing.image import ImageDataGenerator
from tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau, ModelCheckpoint
from tensorflow.keras.optimizers import Adam

print("TensorFlow version:", tf.__version__)

# ============================================
# PART 1: DATASET GENERATOR
# Creates synthetic wing surface images
# ============================================

def create_clean_surface(img_size=224):
    """Creates a realistic-looking metal/aluminum surface (no defect)"""
    # Base color (aircraft aluminum)
    base_color = random.choice([
        (180, 185, 190),   # Light aluminum
        (170, 175, 180),   # Standard aluminum
        (160, 165, 170)    # Darker aluminum
    ])
    
    # Create base image
    img = np.ones((img_size, img_size, 3), dtype=np.uint8)
    img[:,:] = base_color
    
    # Add subtle texture (grain)
    noise = np.random.normal(0, 5, (img_size, img_size, 3))
    img = cv2.add(img.astype(np.float32), noise)
    img = np.clip(img, 0, 255).astype(np.uint8)
    
    # Add light gradient (simulating curved wing surface)
    for i in range(img_size):
        gradient = int(15 * (i / img_size))
        img[i, :, 0] = np.clip(img[i, :, 0] - gradient, 0, 255)
        img[i, :, 2] = np.clip(img[i, :, 2] + gradient, 0, 255)
    
    return img

def add_crack(img):
    """Adds a realistic-looking crack defect"""
    result = img.copy()
    img_size = img.shape[0]
    center_x = random.randint(50, img_size - 50)
    center_y = random.randint(50, img_size - 50)
    
    # Draw jagged crack line
    points = []
    x, y = center_x, center_y
    for _ in range(random.randint(5, 15)):
        points.append((x, y))
        x += random.randint(-8, 8)
        y += random.randint(-8, 8)
        x = max(0, min(img_size - 1, x))
        y = max(0, min(img_size - 1, y))
    
    # Draw the crack
    for i in range(len(points) - 1):
        cv2.line(result, points[i], points[i+1], (30, 30, 35), random.randint(1, 3))
    
    # Add dark shadow around crack
    for i in range(len(points) - 1):
        cv2.line(result, points[i], points[i+1], (20, 20, 25), random.randint(3, 5))
    
    return result

def add_dent(img):
    """Adds a dent/impact mark defect"""
    result = img.copy()
    img_size = img.shape[0]
    center_x = random.randint(60, img_size - 60)
    center_y = random.randint(60, img_size - 60)
    radius = random.randint(10, 35)
    
    # Dark center (shadow)
    cv2.circle(result, (center_x, center_y), radius, (50, 55, 60), -1)
    
    # Highlight ring (light reflection)
    cv2.circle(result, (center_x, center_y), radius-2, (200, 205, 210), 1)
    
    # Add concentric circles for realism
    for r in range(radius-5, radius+5, 3):
        cv2.circle(result, (center_x, center_y), r, (100, 105, 110), 1)
    
    return result

def add_scratch(img):
    """Adds a scratch mark defect"""
    result = img.copy()
    img_size = img.shape[0]
    start_x = random.randint(20, img_size - 20)
    start_y = random.randint(20, img_size - 20)
    end_x = random.randint(20, img_size - 20)
    end_y = random.randint(20, img_size - 20)
    
    # Main scratch
    cv2.line(result, (start_x, start_y), (end_x, end_y), (200, 210, 220), 2)
    
    # Scratch shadow (for depth)
    cv2.line(result, (start_x+1, start_y+1), (end_x+1, end_y+1), (80, 85, 90), 2)
    
    # Small branching scratches
    for _ in range(random.randint(1, 3)):
        mid_x = (start_x + end_x) // 2 + random.randint(-10, 10)
        mid_y = (start_y + end_y) // 2 + random.randint(-10, 10)
        cv2.line(result, (mid_x, mid_y), (mid_x + random.randint(-15, 15), 
                  mid_y + random.randint(-15, 15)), (180, 190, 200), 1)
    
    return result

def create_defect_image(img_size=224):
    """Creates a wing surface with a random defect type"""
    img = create_clean_surface(img_size)
    defect_type = random.choice(['crack', 'dent', 'scratch'])
    
    if defect_type == 'crack':
        img = add_crack(img)
    elif defect_type == 'dent':
        img = add_dent(img)
    else:
        img = add_scratch(img)
    
    return img, defect_type

def generate_dataset(num_clean=150, num_defect=150, img_size=224, output_dir="data/"):
    """Generates the complete dataset"""
    print("\n" + "="*60)
    print("PART 1: GENERATING SYNTHETIC DATASET")
    print("="*60)
    print(f"\nGenerating:")
    print(f"  - {num_clean} clean (no defect) images")
    print(f"  - {num_defect} defect images")
    print(f"  - Total: {num_clean + num_defect} images")
    
    # Create directories
    os.makedirs(os.path.join(output_dir, "defect"), exist_ok=True)
    os.makedirs(os.path.join(output_dir, "no_defect"), exist_ok=True)
    
    # Generate clean images
    print("\n[1/2] Generating clean images...")
    clean_images = []
    for i in range(num_clean):
        img = create_clean_surface(img_size)
        filename = os.path.join(output_dir, "no_defect", f"clean_{i:04d}.png")
        cv2.imwrite(filename, img)
        clean_images.append(img)
        if (i + 1) % 50 == 0:
            print(f"  Generated {i+1}/{num_clean} clean images")
    
    # Generate defect images
    print("\n[2/2] Generating defect images...")
    defect_images = []
    defect_counts = {'crack': 0, 'dent': 0, 'scratch': 0}
    for i in range(num_defect):
        img, defect_type = create_defect_image(img_size)
        defect_counts[defect_type] += 1
        filename = os.path.join(output_dir, "defect", f"{defect_type}_{i:04d}.png")
        cv2.imwrite(filename, img)
        defect_images.append(img)
        if (i + 1) % 50 == 0:
            print(f"  Generated {i+1}/{num_defect} defect images")
    
    print("\n✅ Dataset generation complete!")
    print(f"\nDefect type breakdown:")
    print(f"  - Cracks:    {defect_counts['crack']}")
    print(f"  - Dents:     {defect_counts['dent']}")
    print(f"  - Scratches: {defect_counts['scratch']}")
    
    return clean_images, defect_images

# ============================================
# PART 2: LOAD AND PREPARE DATA
# ============================================

def load_generated_data(data_dir="data/", img_size=224):
    """Loads the generated images from folders"""
    print("\n" + "="*60)
    print("PART 2: LOADING DATASET")
    print("="*60)
    
    defect_images = []
    no_defect_images = []
    
    # Load defect images
    defect_path = os.path.join(data_dir, "defect")
    for filename in os.listdir(defect_path):
        if filename.endswith(('.png', '.jpg', '.jpeg')):
            img = cv2.imread(os.path.join(defect_path, filename))
            img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
            img = cv2.resize(img, (img_size, img_size))
            defect_images.append(img)
    
    # Load no-defect images
    no_defect_path = os.path.join(data_dir, "no_defect")
    for filename in os.listdir(no_defect_path):
        if filename.endswith(('.png', '.jpg', '.jpeg')):
            img = cv2.imread(os.path.join(no_defect_path, filename))
            img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
            img = cv2.resize(img, (img_size, img_size))
            no_defect_images.append(img)
    
    print(f"Loaded {len(defect_images)} defect images")
    print(f"Loaded {len(no_defect_images)} clean images")
    
    return np.array(defect_images), np.array(no_defect_images)

def prepare_data(defect_images, no_defect_images, test_split=0.1, val_split=0.2, seed=42):
    """Splits data into train/validation/test sets"""
    print("\n" + "="*60)
    print("PART 3: PREPARING DATA SPLITS")
    print("="*60)
    
    # Create labels
    X_defect = defect_images
    X_clean = no_defect_images
    y_defect = np.ones(len(X_defect))
    y_clean = np.zeros(len(X_clean))
    
    # Combine
    X = np.vstack([X_defect, X_clean])
    y = np.hstack([y_defect, y_clean])
    
    # Normalize
    X = X.astype('float32') / 255.0
    
    # Shuffle
    np.random.seed(seed)
    indices = np.random.permutation(len(X))
    X = X[indices]
    y = y[indices]
    
    # Split: train+val vs test
    X_temp, X_test, y_temp, y_test = train_test_split(
        X, y, test_size=test_split, random_state=seed, stratify=y
    )
    
    # Split: train vs val
    val_ratio = val_split / (1 - test_split)
    X_train, X_val, y_train, y_val = train_test_split(
        X_temp, y_temp, test_size=val_ratio, random_state=seed, stratify=y_temp
    )
    
    print(f"\nData split completed:")
    print(f"  Training set:   {len(X_train)} images ({int(sum(y_train))} defects, {len(y_train)-int(sum(y_train))} clean)")
    print(f"  Validation set: {len(X_val)} images ({int(sum(y_val))} defects, {len(y_val)-int(sum(y_val))} clean)")
    print(f"  Test set:       {len(X_test)} images ({int(sum(y_test))} defects, {len(y_test)-int(sum(y_test))} clean)")
    
    return X_train, X_val, X_test, y_train, y_val, y_test

# ============================================
# PART 3: DATA AUGMENTATION
# ============================================

def create_data_generators(X_train, y_train, X_val, y_val, X_test, y_test, batch_size=32):
    """Creates augmented data generators"""
    print("\n" + "="*60)
    print("PART 4: CONFIGURING DATA AUGMENTATION")
    print("="*60)
    
    train_datagen = ImageDataGenerator(
        rotation_range=30,
        width_shift_range=0.2,
        height_shift_range=0.2,
        shear_range=0.2,
        zoom_range=0.2,
        horizontal_flip=True,
        fill_mode='nearest'
    )
    
    val_datagen = ImageDataGenerator()
    test_datagen = ImageDataGenerator()
    
    train_generator = train_datagen.flow(X_train, y_train, batch_size=batch_size)
    val_generator = val_datagen.flow(X_val, y_val, batch_size=batch_size)
    test_generator = test_datagen.flow(X_test, y_test, batch_size=batch_size, shuffle=False)
    
    print("Augmentation configured: rotation, shift, zoom, flip")
    
    # Visualize augmentation
    sample_batch, sample_labels = next(train_generator)
    fig, axes = plt.subplots(2, 5, figsize=(15, 6))
    for i, ax in enumerate(axes.flat):
        ax.imshow(sample_batch[i])
        ax.set_title(f"Label: {int(sample_labels[i])}")
        ax.axis('off')
    plt.suptitle("Augmented Training Samples", fontsize=14)
    plt.tight_layout()
    plt.show()
    
    return train_generator, val_generator, test_generator

# ============================================
# PART 4: CNN ARCHITECTURE
# ============================================

def create_cnn_model(input_shape=(224, 224, 3)):
    """Creates the CNN model for defect detection"""
    print("\n" + "="*60)
    print("PART 5: BUILDING CNN ARCHITECTURE")
    print("="*60)
    
    model = Sequential([
        Input(shape=input_shape),
        
        # Block 1
        Conv2D(32, (3, 3), activation='relu', padding='same'),
        BatchNormalization(),
        Conv2D(32, (3, 3), activation='relu', padding='same'),
        BatchNormalization(),
        MaxPooling2D((2, 2)),
        Dropout(0.25),
        
        # Block 2
        Conv2D(64, (3, 3), activation='relu', padding='same'),
        BatchNormalization(),
        Conv2D(64, (3, 3), activation='relu', padding='same'),
        BatchNormalization(),
        MaxPooling2D((2, 2)),
        Dropout(0.25),
        
        # Block 3
        Conv2D(128, (3, 3), activation='relu', padding='same'),
        BatchNormalization(),
        Conv2D(128, (3, 3), activation='relu', padding='same'),
        BatchNormalization(),
        MaxPooling2D((2, 2)),
        Dropout(0.25),
        
        # Dense layers
        Flatten(),
        Dense(512, activation='relu'),
        BatchNormalization(),
        Dropout(0.5),
        Dense(256, activation='relu'),
        Dropout(0.3),
        Dense(1, activation='sigmoid')
    ])
    
    model.summary()
    return model

# ============================================
# PART 5: TRAINING
# ============================================

def train_model(model, train_generator, val_generator, epochs=50):
    """Trains the CNN model"""
    print("\n" + "="*60)
    print("PART 6: TRAINING MODEL")
    print("="*60)
    
    model.compile(
        optimizer=Adam(learning_rate=0.001),
        loss='binary_crossentropy',
        metrics=['accuracy']
    )
    
    callbacks = [
        EarlyStopping(monitor='val_loss', patience=10, restore_best_weights=True, verbose=1),
        ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=5, min_lr=1e-6, verbose=1),
        ModelCheckpoint('best_model.h5', monitor='val_accuracy', save_best_only=True, verbose=1)
    ]
    
    history = model.fit(
        train_generator,
        epochs=epochs,
        validation_data=val_generator,
        callbacks=callbacks,
        verbose=1
    )
    
    return history

# ============================================
# PART 6: EVALUATION
# ============================================

def evaluate_model(model, test_generator, y_test):
    """Evaluates the model and displays results"""
    print("\n" + "="*60)
    print("PART 7: MODEL EVALUATION")
    print("="*60)
    
    y_pred_proba = model.predict(test_generator)
    y_pred = (y_pred_proba > 0.5).astype(int)
    
    accuracy = accuracy_score(y_test[:len(y_pred)], y_pred.flatten())
    precision = precision_score(y_test[:len(y_pred)], y_pred.flatten())
    recall = recall_score(y_test[:len(y_pred)], y_pred.flatten())
    f1 = f1_score(y_test[:len(y_pred)], y_pred.flatten())
    
    print(f"\n{'Metric':<15} {'Score':<10}")
    print("-" * 30)
    print(f"{'Accuracy':<15} {accuracy:.4f} ({accuracy*100:.1f}%)")
    print(f"{'Precision':<15} {precision:.4f}")
    print(f"{'Recall':<15} {recall:.4f}")
    print(f"{'F1-Score':<15} {f1:.4f}")
    
    print("\nClassification Report:")
    print(classification_report(y_test[:len(y_pred)], y_pred.flatten(), 
                                target_names=['No Defect', 'Defect']))
    
    # Confusion Matrix
    cm = confusion_matrix(y_test[:len(y_pred)], y_pred.flatten())
    plt.figure(figsize=(8, 6))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=['No Defect', 'Defect'],
                yticklabels=['No Defect', 'Defect'])
    plt.title('Confusion Matrix - Test Set Results')
    plt.xlabel('Predicted')
    plt.ylabel('Actual')
    plt.tight_layout()
    plt.savefig('confusion_matrix.png', dpi=150)
    plt.show()
    
    return accuracy, precision, recall, f1

def plot_training_history(history):
    """Plots training accuracy and loss curves"""
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))
    
    ax1.plot(history.history['accuracy'], 'b-o', label='Training')
    ax1.plot(history.history['val_accuracy'], 'r-o', label='Validation')
    ax1.set_title('Model Accuracy')
    ax1.set_xlabel('Epoch')
    ax1.set_ylabel('Accuracy')
    ax1.legend()
    ax1.grid(True)
    
    ax2.plot(history.history['loss'], 'b-o', label='Training')
    ax2.plot(history.history['val_loss'], 'r-o', label='Validation')
    ax2.set_title('Model Loss')
    ax2.set_xlabel('Epoch')
    ax2.set_ylabel('Loss')
    ax2.legend()
    ax2.grid(True)
    
    plt.tight_layout()
    plt.savefig('training_history.png', dpi=150)
    plt.show()

# ============================================
# MAIN EXECUTION
# ============================================

if __name__ == "__main__":
    print("\n" + "="*60)
    print("AIRCRAFT WING DEFECT DETECTION SYSTEM")
    print("Team: Erika, Nikita, Danik")
    print("="*60)
    
    # Step 1: Generate dataset
    NUM_CLEAN = 200      # You can change this
    NUM_DEFECT = 200     # You can change this
    IMG_SIZE = 224
    
    generate_dataset(num_clean=NUM_CLEAN, num_defect=NUM_DEFECT, img_size=IMG_SIZE)
    
    # Step 2: Load data
    defect_images, clean_images = load_generated_data(img_size=IMG_SIZE)
    
    # Step 3: Prepare splits
    X_train, X_val, X_test, y_train, y_val, y_test = prepare_data(
        defect_images, clean_images
    )
    
    # Step 4: Create data generators with augmentation
    train_gen, val_gen, test_gen = create_data_generators(
        X_train, y_train, X_val, y_val, X_test, y_test
    )
    
    # Step 5: Build model
    model = create_cnn_model(input_shape=(IMG_SIZE, IMG_SIZE, 3))
    
    # Step 6: Train model
    history = train_model(model, train_gen, val_gen)
    
    # Step 7: Plot results
    plot_training_history(history)
    
    # Step 8: Evaluate
    accuracy, precision, recall, f1 = evaluate_model(model, test_gen, y_test)
    
    # Step 9: Final summary
    print("\n" + "="*60)
    print("FINAL SUMMARY")
    print("="*60)
    print(f"\n✅ Dataset: {NUM_CLEAN + NUM_DEFECT} images generated")
    print(f"✅ Training completed: {len(history.history['accuracy'])} epochs")
    print(f"✅ Test Accuracy: {accuracy*100:.1f}%")
    print(f"✅ F1-Score: {f1:.3f}")
    print("\n📁 Files saved:")
    print("   - best_model.h5 (trained model)")
    print("   - training_history.png (accuracy/loss plots)")
    print("   - confusion_matrix.png (test results)")
    print("   - data/ folder (generated dataset)")
    print("\n" + "="*60)
